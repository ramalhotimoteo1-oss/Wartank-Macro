#!/bin/bash
# ============================================================
# pvp.sh — Módulo PvP (Versão Melhorada)
# ============================================================

# ── Configurações ────────────────────────────────────────────
PVP_MAX_RETRIES="${PVP_MAX_RETRIES:-3}"
PVP_TIMEOUT_QUEUE="${PVP_TIMEOUT_QUEUE:-300}"  # 5 minutos
PVP_TIMEOUT_BATTLE="${PVP_TIMEOUT_BATTLE:-900}" # 15 minutos
PVP_SLEEP_AFTER_BATTLE="${PVP_SLEEP_AFTER_BATTLE:-3}"
PVP_SLEEP_REFRESH="${PVP_SLEEP_REFRESH:-2}"

# ── Logging aprimorado ───────────────────────────────────────
_pvp_log() {
  local level="$1" msg="$2" icon="$3"
  case "$level" in
    DEBUG) echo_t "  [DEBUG] $msg" "$GRAY_BLACK" "$COLOR_RESET" ;;
    INFO)  echo_t "  ℹ️ $msg" "$BLUE_BLACK" "$COLOR_RESET" ;;
    WARN)  echo_t "  ⚠️ $msg" "$BLACK_YELLOW" "$COLOR_RESET" ;;
    ERROR) echo_t "  ❌ $msg" "$BLACK_RED" "$COLOR_RESET" ;;
    OK)    echo_t "  ✅ $msg" "$GREEN_BLACK" "$COLOR_RESET" ;;
  esac
}

# ── Fetch com retry ──────────────────────────────────────────
_pvp_fetch() {
  local url="$1" retries="${PVP_MAX_RETRIES}" retry_count=0
  
  while [ "$retry_count" -lt "$retries" ]; do
    if fetch_page "$url"; then
      return 0
    fi
    retry_count=$(( retry_count + 1 ))
    if [ "$retry_count" -lt "$retries" ]; then
      _pvp_log "WARN" "Fetch falhou, retry ${retry_count}/${retries}..."
      sleep 2s
    fi
  done
  
  _pvp_log "ERROR" "Falha ao buscar: $url (após $retries tentativas)"
  return 1
}

# ── Validação de variáveis numéricas ─────────────────────────
_pvp_is_numeric() {
  [ ! -z "$1" ] && [ "$1" -eq "$1" ] 2>/dev/null
}

# ── Entrar na fila PvP ───────────────────────────────────────
_pvp_enter() {
  _pvp_fetch "/pvp" || return 1
  
  # Extrai link de entrada com tratamento melhorado
  local join
  join=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-joinLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  
  if [ -z "$join" ]; then
    _pvp_log "ERROR" "Não foi possível encontrar link de entrada PvP"
    return 1
  fi
  
  _pvp_log "INFO" "A entrar na fila..."
  _pvp_fetch "/${join}" || return 1
  sleep "${PVP_SLEEP_REFRESH}s"
  return 0
}

# ── Aguarda batalha iniciar ──────────────────────────────────
_pvp_wait_battle_start() {
  local timeout=$(( $(date +%s) + ${PVP_TIMEOUT_QUEUE} ))
  local interval="${PVP_REFRESH_INTERVAL:-10}"
  local n=0
  
  _pvp_log "INFO" "À espera de jogadores (timeout: ${PVP_TIMEOUT_QUEUE}s)..."
  
  while [ "$(date +%s)" -lt "$timeout" ]; do
    
    # Verifica se batalha começou
    if grep -q 'attackRegularShellLink\|attackSpecialShellLink' "$TMP/SRC" 2>/dev/null; then
      _pvp_log "OK" "Batalha iniciada!"
      return 0
    fi
    
    # Refresh
    local refresh
    refresh=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-refreshLink' \
      "$TMP/SRC" 2>/dev/null | head -n1)
    
    if [ -n "$refresh" ]; then
      _pvp_fetch "/${refresh}" || _pvp_fetch "/pvp"
    else
      _pvp_fetch "/pvp"
    fi
    
    n=$(( n + 1 ))
    _pvp_log "DEBUG" "Refresh #${n}... (${interval}s)"
    sleep "${interval}s"
  done
  
  _pvp_log "WARN" "Timeout na fila após ${PVP_TIMEOUT_QUEUE}s"
  return 1
}

# ── Extrai dados de combate com validação ────────────────────
_pvp_extract() {
  # Links de ação
  PVP_ATK=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-attackRegularShellLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  PVP_ATK_SPECIAL=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-attackSpecialShellLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  PVP_REPAIR=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-repairLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  PVP_MANEUVER=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-maneuverLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  PVP_CHANGE=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-changeTargetLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  PVP_ESCAPE=$(grep -o -E 'pvp[^"]*\?[0-9]+-[0-9]+\.ILinkListener-escapeLink' \
    "$TMP/SRC" 2>/dev/null | head -n1)
  
  # HP com validação melhorada
  local hp_values
  hp_values=$(grep -o -E 'value-block lh1[^>]*>[^<]*<[^>]*>[^<]*>[0-9]+' "$TMP/SRC" 2>/dev/null \
    | grep -o -E '[0-9]+$')
  
  PVP_HP_PLAYER=$(echo "$hp_values" | sed -n '1p')
  PVP_HP_ENEMY=$(echo "$hp_values" | sed -n '2p')
  
  # Nomes com fallback
  PVP_NAME_PLAYER=$(grep -o -E 'class="small bold green1[^>]*>[^<]+' "$TMP/SRC" 2>/dev/null \
    | sed 's/.*">//' | head -n1)
  PVP_NAME_ENEMY=$(grep -o -E 'class="small bold red1[^>]*>[^<]+' "$TMP/SRC" 2>/dev/null \
    | sed 's/.*">//' | head -n1)
  
  # Tanques
  PVP_TANKS=$(grep -o -E 'dos Tanques no combate: [0-9]+' "$TMP/SRC" 2>/dev/null \
    | grep -o -E '[0-9]+' | head -n1)
  
  # Validações
  if ! _pvp_is_numeric "$PVP_HP_PLAYER"; then PVP_HP_PLAYER="?"; fi
  if ! _pvp_is_numeric "$PVP_HP_ENEMY"; then PVP_HP_ENEMY="?"; fi
}

# ── Calcula percentual de HP ─────────────────────────────────
_pvp_get_hp_percent() {
  local hp="$1" hp_max="$2"
  
  if ! _pvp_is_numeric "$hp" || ! _pvp_is_numeric "$hp_max" || [ "$hp_max" -eq 0 ]; then
    echo "0"
    return
  fi
  
  awk -v n="$hp" -v m="$hp_max" 'BEGIN { printf "%.0f", n/m*100 }'
}

# ── Disparo com repair e manobra ─────────────────────────────
_pvp_shoot() {
  _pvp_extract
  
  # Batalha terminou?
  if [ -z "$PVP_ATK" ] && [ -z "$PVP_ESCAPE" ]; then
    return 1
  fi
  
  # Repair se HP baixo
  if [ -n "$PVP_REPAIR" ] && _pvp_is_numeric "$PVP_HP_PLAYER"; then
    local now since_repair hp_pct
    now=$(date +%s)
    since_repair=$(( now - ${_PVP_LAST_REPAIR:-0} ))
    
    hp_pct=$(_pvp_get_hp_percent "$PVP_HP_PLAYER" "${_PVP_HP_MAX:-100}")
    
    if [ "$hp_pct" -le "${BATTLE_REPAIR_PCT:-30}" ] && \
       [ "$since_repair" -ge "${BATTLE_REPAIR_CD:-90}" ]; then
      _pvp_log "WARN" "Repair! HP: ${PVP_HP_PLAYER} (${hp_pct}%)"
      _pvp_fetch "/${PVP_REPAIR}" || true
      _PVP_LAST_REPAIR=$(date +%s)
      _pvp_extract
    fi
  fi
  
  # Manobra se foi atingido
  if [ -n "$PVP_MANEUVER" ]; then
    local now since_maneuver
    now=$(date +%s)
    since_maneuver=$(( now - ${_PVP_LAST_MANEUVER:-0} ))
    
    if [ "$since_maneuver" -ge "${BATTLE_MANEUVER_CD:-20}" ] && \
       grep -qi "disparou a.*${PVP_NAME_PLAYER}\|RICOCHETE" "$TMP/SRC" 2>/dev/null; then
      _pvp_log "INFO" "Manobra ativada!"
      _pvp_fetch "/${PVP_MANEUVER}" || true
      _PVP_LAST_MANEUVER=$(date +%s)
      _pvp_extract
    fi
  fi
  
  # Disparo
  if [ -n "$PVP_ATK" ]; then
    _pvp_fetch "/${PVP_ATK}" || return 1
    sleep "${BATTLE_LA:-3}s"
    _pvp_extract
    return 0
  fi
  
  return 1
}

# ── Batalha completa ─────────────────────────────────────────
_pvp_fight_full() {
  _pvp_extract
  _PVP_LAST_REPAIR=0
  _PVP_LAST_MANEUVER=0
  _PVP_HP_MAX="$PVP_HP_PLAYER"
  
  local shots=0
  local timeout=$(( $(date +%s) + ${PVP_TIMEOUT_BATTLE} ))
  
  while [ "$(date +%s)" -lt "$timeout" ]; do
    _pvp_extract
    
    # Fim de batalha
    if [ -z "$PVP_ATK" ] && [ -z "$PVP_ESCAPE" ]; then
      _pvp_log "OK" "Batalha terminada!"
      break
    fi
    
    if _pvp_shoot; then
      shots=$(( shots + 1 ))
      _pvp_log "DEBUG" "#${shots} | HP: ${PVP_HP_PLAYER} vs ${PVP_HP_ENEMY} | Tanques: ${PVP_TANKS}"
    else
      sleep 2s
    fi
  done
  
  _pvp_log "OK" "Disparos totais: ${shots}"
}

# ── Batalha limitada ─────────────────────────────────────────
_pvp_fight_limited() {
  local max="${1:-5}"
  _pvp_extract
  _PVP_LAST_REPAIR=0
  _PVP_LAST_MANEUVER=0
  _PVP_HP_MAX="$PVP_HP_PLAYER"
  
  local shots=0
  while [ "$shots" -lt "$max" ]; do
    _pvp_extract
    if [ -z "$PVP_ATK" ]; then 
      sleep 2s
      continue
    fi
    if _pvp_shoot; then
      shots=$(( shots + 1 ))
      _pvp_log "DEBUG" "Disparo ${shots}/${max}"
    fi
  done
}

# ── Abandonar batalha ────────────────────────────────────────
_pvp_escape() {
  _pvp_extract
  if [ -n "$PVP_ESCAPE" ]; then
    _pvp_log "WARN" "A abandonar batalha..."
    _pvp_fetch "/${PVP_ESCAPE}" || true
    sleep "${PVP_SLEEP_AFTER_BATTLE}s"
  fi
}

# ── Modo PvP principal ───────────────────────────────────────
pvp_mode() {
  _pvp_log "OK" "Iniciando Batalhas PvP 🏆"
  
  local battle_num=0
  local total="${PVP_BATTLES:-4}"
  
  while [ "$battle_num" -lt "$total" ]; do
    battle_num=$(( battle_num + 1 ))
    _pvp_log "OK" "Batalha PvP ${battle_num}/${total} ⚔️"
    
    if ! _pvp_enter; then
      _pvp_log "ERROR" "Não foi possível entrar no PvP. Abortando."
      break
    fi
    
    if ! _pvp_wait_battle_start; then
      _pvp_log "WARN" "Timeout na fila. Pulando para próxima battaglia."
      continue
    fi
    
    # Estratégias
    case "$battle_num" in
      1)
        _pvp_log "DEBUG" "Estratégia: Batalha completa"
        _pvp_fight_full
        ;;
      2|3)
        _pvp_log "DEBUG" "Estratégia: Abandono imediato"
        sleep 2s
        _pvp_escape
        ;;
      4)
        _pvp_log "DEBUG" "Estratégia: 5 disparos e abandonar"
        _pvp_fight_limited 5
        _pvp_escape
        ;;
    esac
    
    _pvp_log "OK" "Batalha ${battle_num} concluída."
    sleep "${PVP_SLEEP_AFTER_BATTLE}s"
  done
  
  _pvp_log "OK" "PvP concluído!"
  go_hangar
}
